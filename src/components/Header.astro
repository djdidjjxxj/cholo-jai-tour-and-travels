---
import { siteConfig } from '../data/siteConfig';
import { Phone, Mail } from 'lucide-astro';
---

<header class="header">
  <div class="header-top">
    <div class="container top-bar">
      <div class="contact-info">
        <a href={`tel:${siteConfig.phoneNumbers[0].replace(/\s/g, '')}`} class="contact-link">
          <Phone size={16} /> {siteConfig.phoneNumbers[0]}
        </a>
        <a href={`mailto:${siteConfig.email}`} class="contact-link">
          <Mail size={16} /> {siteConfig.email}
        </a>
      </div>
      <div class="social-links">
        <span class="trust-badge">Govt. Registered Agency</span>
      </div>
    </div>
  </div>
  
  <div class="header-main">
    <div class="container nav-container">
      <a href="/" class="logo-link">
        <img src="/logo.png" alt={siteConfig.logoAlt} class="logo" onerror="this.src='/images/tour-1.jpeg'; this.classList.add('logo-fallback');" />
      </a>

      <nav class="desktop-nav">
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/packages">Packages</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>

      <div class="nav-actions">
        <a href="/contact" class="btn btn-primary desktop-book">Book Now</a>
        <!-- Hamburger button -->
        <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div class="mobile-drawer" id="mobile-drawer">
    <div class="drawer-header">
      <a href="/" class="logo-link">
        <img src="/logo.png" alt="Cholo Jai" class="logo" onerror="this.src='/images/tour-1.jpeg'" />
      </a>
      <button class="drawer-close" id="drawer-close" aria-label="Close menu">&#x2715;</button>
    </div>
    <nav class="drawer-nav">
      <a href="/">Home</a>
      <a href="/packages">Packages</a>
      <a href="/about">About</a>
      <a href="/gallery">Gallery</a>
      <a href="/contact">Contact</a>
    </nav>
    <div class="drawer-contact">
      <a href="tel:9830905332">📞 98309 05332</a>
      <a href="mailto:cholojai2013@gmail.com">✉ cholojai2013@gmail.com</a>
    </div>
    <a href="/contact" class="btn btn-primary drawer-book">Book Now</a>
  </div>
  <div class="drawer-backdrop" id="drawer-backdrop"></div>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const drawer = document.getElementById('mobile-drawer');
  const backdrop = document.getElementById('drawer-backdrop');
  const closeBtn = document.getElementById('drawer-close');

  function openDrawer() {
    drawer?.classList.add('open');
    backdrop?.classList.add('open');
    hamburger?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer?.classList.remove('open');
    backdrop?.classList.remove('open');
    hamburger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  // Close on nav link click
  drawer?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeDrawer);
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--c-neutral);
    box-shadow: var(--shadow-sm);
  }

  .header-top {
    background-color: var(--c-primary);
    color: var(--c-neutral);
    padding: 8px 0;
    font-size: 0.875rem;
  }

  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .contact-info {
    display: flex;
    gap: 20px;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0.9;
  }

  .contact-link:hover {
    opacity: 1;
  }

  .trust-badge {
    font-weight: 500;
    letter-spacing: 0.5px;
    opacity: 0.9;
  }

  .header-main {
    padding: 15px 0;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    height: 60px;
    width: auto;
    object-fit: contain;
  }

  .logo-fallback {
    height: 40px;
    border-radius: var(--radius-sm);
  }

  .nav-links {
    display: flex;
    gap: 32px;
  }

  .nav-links a {
    font-family: var(--f-heading);
    font-weight: 500;
    color: var(--c-text);
    position: relative;
    padding: 5px 0;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--c-accent);
    transition: var(--transition);
  }

  .nav-links a:hover {
    color: var(--c-primary);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  /* Hamburger button — base: hidden on desktop */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 200;
  }

  @media (max-width: 768px) {
    .header-top {
      display: none;
    }
    .desktop-nav {
      display: none;
    }
    .desktop-book {
      display: none;
    }
    .logo {
      height: 45px;
    }
    .hamburger {
      display: flex !important;
    }
  }

  .hamburger span {
    display: block;
    width: 100%;
    height: 2.5px;
    background: var(--c-primary);
    border-radius: 3px;
    transition: all 0.3s ease;
  }

  /* Mobile Drawer */
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: -100%;
    width: min(320px, 85vw);
    height: 100dvh;
    background: #fff;
    z-index: 300;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    gap: 1.5rem;
    box-shadow: -4px 0 30px rgba(0,0,0,0.15);
    transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
  }

  .mobile-drawer.open {
    right: 0;
  }

  .drawer-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 250;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(2px);
  }

  .drawer-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }

  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--c-border);
    padding-bottom: 1rem;
  }

  .drawer-close {
    background: none;
    border: none;
    font-size: 1.4rem;
    cursor: pointer;
    color: var(--c-text);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.2s;
  }

  .drawer-close:hover {
    background: var(--c-bg-light);
  }

  .drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .drawer-nav a {
    font-family: var(--f-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--c-text);
    padding: 0.75rem 0.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
    border-bottom: 1px solid var(--c-border);
  }

  .drawer-nav a:hover {
    color: var(--c-accent);
    background: var(--c-bg-light);
    padding-left: 1rem;
  }

  .drawer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--c-border);
  }

  .drawer-contact a {
    font-size: 0.9rem;
    color: var(--c-text-muted);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .drawer-contact a:hover {
    color: var(--c-accent);
  }

  .drawer-book {
    text-align: center;
    width: 100%;
  }
</style>
