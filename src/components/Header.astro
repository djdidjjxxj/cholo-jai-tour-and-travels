---
import { siteConfig } from '../data/siteConfig';
import { Phone, Mail } from 'lucide-astro';
---

<header class="header">
  <div class="header-top">
    <div class="container top-bar">
      <div class="contact-info">
        <a href={`tel:${siteConfig.phoneNumbers[0].replace(/\s/g, '')}`} class="contact-link">
          <Phone size={16} /> {siteConfig.phoneNumbers[0]}
        </a>
        <a href={`mailto:${siteConfig.email}`} class="contact-link">
          <Mail size={16} /> {siteConfig.email}
        </a>
      </div>
      <div class="social-links">
        <span class="trust-badge">Govt. Registered Agency</span>
      </div>
    </div>
  </div>
  
  <div class="header-main">
    <div class="container nav-container">
      <a href="/" class="logo-link">
        <img src="/logo.png" alt={siteConfig.logoAlt} class="logo" onerror="this.src='/images/tour-1.jpeg'; this.classList.add('logo-fallback');" />
      </a>

      <nav class="desktop-nav">
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/packages">Packages</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>

      <div class="nav-actions">
        <a href="/contact" class="btn btn-primary">Book Now</a>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--c-neutral);
    box-shadow: var(--shadow-sm);
  }

  .header-top {
    background-color: var(--c-primary);
    color: var(--c-neutral);
    padding: 8px 0;
    font-size: 0.875rem;
  }

  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .contact-info {
    display: flex;
    gap: 20px;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0.9;
  }

  .contact-link:hover {
    opacity: 1;
  }

  .trust-badge {
    font-weight: 500;
    letter-spacing: 0.5px;
    opacity: 0.9;
  }

  .header-main {
    padding: 15px 0;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    height: 60px;
    width: auto;
    object-fit: contain;
  }

  .logo-fallback {
    height: 40px;
    border-radius: var(--radius-sm);
  }

  .nav-links {
    display: flex;
    gap: 32px;
  }

  .nav-links a {
    font-family: var(--f-heading);
    font-weight: 500;
    color: var(--c-text);
    position: relative;
    padding: 5px 0;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--c-accent);
    transition: var(--transition);
  }

  .nav-links a:hover {
    color: var(--c-primary);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  @media (max-width: 768px) {
    .header-top {
      display: none;
    }
    .desktop-nav {
      display: none;
    }
    .logo {
      height: 45px;
    }
  }
</style>
