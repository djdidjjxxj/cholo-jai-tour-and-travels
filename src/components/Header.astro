---
import { siteConfig } from '../data/siteConfig';
import { Phone, Mail } from 'lucide-astro';
---

<header class="site-header" id="site-header">
  <!-- Top bar -->
  <div class="top-bar">
    <div class="container top-bar-inner">
      <div class="top-contacts">
        <a href={`tel:${siteConfig.phoneNumbers[0].replace(/\s/g, '')}`} class="top-link">
          <Phone size={14} /> {siteConfig.phoneNumbers[0]}
        </a>
        <a href={`mailto:${siteConfig.email}`} class="top-link">
          <Mail size={14} /> {siteConfig.email}
        </a>
      </div>
      <span class="trust-badge">Govt. Registered Agency</span>
    </div>
  </div>

  <!-- Main nav -->
  <div class="nav-bar">
    <div class="container nav-inner">
      <!-- Logo → always goes home -->
      <a href="/" class="logo-link" aria-label="Go to homepage">
        <img src="/images/icon.png" alt="Cholo Jai" class="logo-img"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='block'" />
        <span class="logo-text" style="display:none">Cholo Jai</span>
      </a>

      <!-- Desktop nav -->
      <nav class="desktop-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/packages">Packages</a>
        <a href="/about">About</a>
        <a href="/gallery">Gallery</a>
        <a href="/contact">Contact</a>
      </nav>

      <div class="nav-end">
        <a href="https://wa.me/919830905332?text=Hi%2C%20I%20want%20to%20book%20a%20tour!" target="_blank" rel="noopener" class="btn btn-primary desktop-only">Book Now</a>
        <!-- Hamburger -->
        <button class="burger" id="burger-btn" aria-label="Open menu" aria-expanded="false" type="button">
          <span class="bline"></span>
          <span class="bline"></span>
          <span class="bline"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile drawer (outside header so z-index stacking is clean) -->
<div class="drawer" id="nav-drawer" aria-hidden="true">
  <div class="drawer-top">
    <a href="/" class="logo-link">
      <img src="/images/icon.png" alt="Cholo Jai" class="logo-img-sm"
           onerror="this.style.display='none'" />
      <span class="drawer-brand">Cholo Jai</span>
    </a>
    <button class="drawer-x" id="drawer-close-btn" aria-label="Close menu" type="button">✕</button>
  </div>

  <nav class="drawer-links">
    <a href="/">Home</a>
    <a href="/packages">Packages</a>
    <a href="/about">About</a>
    <a href="/gallery">Gallery</a>
    <a href="/contact">Contact</a>
  </nav>

  <div class="drawer-contact-list">
    <a href={`tel:${siteConfig.phoneNumbers[0].replace(/\s/g, '')}`}>{siteConfig.phoneNumbers[0]}</a>
    <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
  </div>

  <a href="https://wa.me/919830905332?text=Hi%2C%20I%20want%20to%20book%20a%20tour!" target="_blank" rel="noopener" class="drawer-wa-btn">
    Book on WhatsApp
  </a>
</div>
<div class="drawer-bg" id="drawer-bg"></div>

<script>
  // Use a self-contained function to avoid ViewTransitions re-init issues
  function initNav() {
    const burgerBtn = document.getElementById('burger-btn');
    const drawer    = document.getElementById('nav-drawer');
    const drawerBg  = document.getElementById('drawer-bg');
    const closeBtn  = document.getElementById('drawer-close-btn');

    if (!burgerBtn || !drawer || !drawerBg) return;

    let open = false;

    function openDrawer() {
      open = true;
      drawer.classList.add('open');
      drawerBg.classList.add('open');
      burgerBtn.setAttribute('aria-expanded', 'true');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      open = false;
      drawer.classList.remove('open');
      drawerBg.classList.remove('open');
      burgerBtn.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    burgerBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      open ? closeDrawer() : openDrawer();
    });

    closeBtn?.addEventListener('click', closeDrawer);
    drawerBg.addEventListener('click', closeDrawer);

    // Close on nav link tap
    drawer.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeDrawer);
    });

    // Mobile Scroll Animation Logic
    let lastScrollY = window.scrollY;
    const header = document.getElementById('site-header');

    function handleScroll() {
      if (window.innerWidth > 768 || !header) return;
      const currentScrollY = window.scrollY;
      
      if (currentScrollY > lastScrollY && currentScrollY > 60) {
        // Scrolling down
        header.classList.add('scroll-down');
      } else if (currentScrollY < lastScrollY) {
        // Scrolling up
        header.classList.remove('scroll-down');
      }
      lastScrollY = currentScrollY;
    }
    
    window.removeEventListener('scroll', handleScroll);
    window.addEventListener('scroll', handleScroll, { passive: true });
  }

  // Run on first load and after every Astro page transition
  document.addEventListener('astro:page-load', initNav);
  initNav();
</script>

<style>
  /* ── Top bar ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 200;
    background: #fff;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  .top-bar {
    background: var(--c-primary);
    padding: 6px 0;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.9);
  }

  .top-bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
  }

  .top-contacts {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .top-link {
    display: flex;
    align-items: center;
    gap: 5px;
    color: rgba(255,255,255,0.9);
    text-decoration: none;
    transition: color 0.2s;
  }

  .top-link:hover { color: #fff; }

  .trust-badge {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    opacity: 0.9;
  }

  /* ── Main nav ── */
  .nav-bar {
    padding: 6px 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 64px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  .logo-text {
    font-family: var(--f-heading);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--c-primary);
  }

  .desktop-nav {
    display: flex;
    gap: 28px;
    align-items: center;
  }

  .desktop-nav a {
    font-family: var(--f-heading);
    font-weight: 500;
    color: var(--c-text);
    text-decoration: none;
    font-size: 0.95rem;
    padding: 4px 0;
    position: relative;
    transition: color 0.2s;
  }

  .desktop-nav a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--c-accent);
    transition: width 0.25s ease;
  }

  .desktop-nav a:hover { color: var(--c-primary); }
  .desktop-nav a:hover::after { width: 100%; }

  .nav-end {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* ── Hamburger ── */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 22px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }

  .bline {
    display: block;
    width: 100%;
    height: 2.5px;
    background: var(--c-primary);
    border-radius: 3px;
    transition: transform 0.3s, opacity 0.3s;
    pointer-events: none;
  }

  /* ── Drawer ── */
  .drawer {
    position: fixed;
    top: 0;
    right: -110%;
    width: min(320px, 88vw);
    height: 100dvh;
    background: #fff;
    z-index: 500;
    display: flex;
    flex-direction: column;
    padding: 20px;
    gap: 20px;
    box-shadow: -6px 0 32px rgba(0,0,0,0.18);
    transition: right 0.32s cubic-bezier(0.4,0,0.2,1);
    overflow-y: auto;
  }

  .drawer.open { right: 0; }

  .drawer-bg {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.48);
    z-index: 450;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(2px);
  }

  .drawer-bg.open {
    opacity: 1;
    pointer-events: auto;
  }

  .drawer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--c-border);
    padding-bottom: 16px;
  }

  .logo-img-sm {
    height: 60px;
    width: auto;
    object-fit: contain;
  }

  .drawer-brand {
    font-family: var(--f-heading);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--c-primary);
    margin-left: 8px;
  }

  .drawer-x {
    background: none;
    border: none;
    font-size: 1.3rem;
    cursor: pointer;
    color: var(--c-text);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .drawer-x:hover { background: #f1f1f1; }

  .drawer-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .drawer-links a {
    font-family: var(--f-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--c-text);
    text-decoration: none;
    padding: 12px 10px;
    border-radius: 10px;
    transition: all 0.2s;
    border-bottom: 1px solid var(--c-border);
  }

  .drawer-links a:hover {
    background: var(--c-bg-light);
    color: var(--c-accent);
    padding-left: 18px;
  }

  .drawer-contact-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid var(--c-border);
  }

  .drawer-contact-list a {
    font-size: 0.88rem;
    color: var(--c-text-muted);
    text-decoration: none;
  }

  .drawer-contact-list a:hover { color: var(--c-accent); }

  .drawer-wa-btn {
    display: block;
    text-align: center;
    background: #25D366;
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 12px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .drawer-wa-btn:hover { background: #1aa84f; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .top-bar { display: none; }
    .nav-bar { padding: 4px 0; }
    .desktop-nav { display: none; }
    .desktop-only { display: none !important; }
    .logo-img { height: 56px; }
    .burger { display: flex !important; }
    
    /* Scroll Animation Styles */
    .nav-inner { position: relative; }
    .logo-link {
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .site-header.scroll-down .logo-link {
      transform: translateX(calc(50vw - 5vw - 50%));
    }
    
    .burger {
      transition: opacity 0.3s, transform 0.3s;
    }
    .site-header.scroll-down .burger {
      opacity: 0;
      pointer-events: none;
      transform: scale(0.8);
    }
  }
</style>
