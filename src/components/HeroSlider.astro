---
const slides = [
  {
    image: "/images/hero_kashmir_1783678442997.png",
    destination: "Kashmir",
    price: "₹12,999",
    duration: "5 Days / 4 Nights",
    tagline: "Paradise on Earth"
  },
  {
    image: "/images/hero_goa_1783678456678.png",
    destination: "Goa",
    price: "₹9,999",
    duration: "3 Days / 2 Nights",
    tagline: "Sun, Sand & Sea"
  },
  {
    image: "/images/hero_darjeeling_1783678472536.png",
    destination: "Darjeeling",
    price: "₹11,499",
    duration: "4 Days / 3 Nights",
    tagline: "Queen of the Hills"
  },
  {
    image: "/images/hero_andaman_1783678485939.png",
    destination: "Andaman",
    price: "₹13,999",
    duration: "6 Days / 5 Nights",
    tagline: "Island Life Awaits"
  },
  {
    image: "/images/hero_kerala_1783678518411.png",
    destination: "Kerala",
    price: "₹10,999",
    duration: "4 Days / 3 Nights",
    tagline: "God's Own Country"
  }
];
---

<section class="hero-slider-wrap" id="hero-slider">
  <div class="hs-track" id="hs-track">
    {slides.map((slide, i) => (
      <div class={`hs-slide ${i === 0 ? 'active' : ''}`} data-index={i}>
        <img src={slide.image} alt={slide.destination} class="hs-bg" loading={i === 0 ? "eager" : "lazy"} />
        <div class="hs-overlay"></div>
        <div class="hs-caption">
          <span class="hs-tagline">{slide.tagline}</span>
          <h1 class="hs-destination">{slide.destination}</h1>
          <div class="hs-meta">
            <span class="hs-price">{slide.price} <em>per person</em></span>
            <span class="hs-sep">•</span>
            <span class="hs-duration">{slide.duration}</span>
          </div>
          <div class="hs-btns">
            <a href="/packages" class="hs-btn hs-btn-primary">Explore Package</a>
            <a href="https://wa.me/919830905332?text=Hi%2C%20I%20want%20to%20book%20a%20tour%20from%20Cholo%20Jai%20Tour%20%26%20Travels!" target="_blank" rel="noopener" class="hs-btn hs-btn-outline">Book on WhatsApp</a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Dot pagination only -->
  <div class="hs-dots" id="hs-dots">
    {slides.map((_, i) => (
      <button class={`hs-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Go to slide ${i + 1}`}></button>
    ))}
  </div>
</section>

<style>
  .hero-slider-wrap {
    position: relative;
    width: 100%;
    height: 58vh;
    min-height: 380px;
    max-height: 640px;
    overflow: hidden;
    background: #111;
  }

  .hs-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.9s ease;
    pointer-events: none;
  }

  .hs-slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .hs-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hs-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.15) 0%,
      rgba(0,0,0,0.55) 60%,
      rgba(0,0,0,0.82) 100%
    );
  }

  .hs-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 3rem 5vw 5rem;
    color: #fff;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .hs-tagline {
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #f5c842;
    font-weight: 600;
  }

  .hs-destination {
    font-size: clamp(2.4rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    margin: 0;
    color: #fff;
    text-shadow: 0 2px 16px rgba(0,0,0,0.4);
  }

  .hs-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    color: rgba(255,255,255,0.9);
    flex-wrap: wrap;
  }

  .hs-price {
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
  }

  .hs-price em {
    font-style: normal;
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(255,255,255,0.7);
  }

  .hs-sep {
    opacity: 0.5;
  }

  .hs-duration {
    font-size: 0.95rem;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    backdrop-filter: blur(4px);
  }

  .hs-btns {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .hs-btn {
    display: inline-block;
    padding: 0.75rem 1.8rem;
    border-radius: 4px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .hs-btn-primary {
    background: #e86c1a;
    color: #fff;
  }

  .hs-btn-primary:hover {
    background: #cf5c10;
    transform: translateY(-2px);
  }

  .hs-btn-outline {
    color: #fff;
    border: 2px solid rgba(255,255,255,0.7);
    background: transparent;
  }

  .hs-btn-outline:hover {
    background: rgba(255,255,255,0.15);
    border-color: #fff;
    transform: translateY(-2px);
  }

  /* Arrows */
  .hs-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    font-size: 1.4rem;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 10;
    backdrop-filter: blur(4px);
  }

  .hs-arrow:hover {
    background: rgba(232,108,26,0.8);
    border-color: transparent;
  }

  .hs-prev { left: 1.5rem; }
  .hs-next { right: 1.5rem; }

  /* Dots */
  .hs-dots {
    position: absolute;
    bottom: 1.5rem;
    right: 5vw;
    display: flex;
    gap: 0.5rem;
    z-index: 10;
  }

  .hs-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    padding: 0;
  }

  .hs-dot.active {
    background: #e86c1a;
    width: 28px;
    border-radius: 6px;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .hero-slider-wrap {
      height: 48vh;
      min-height: 320px;
      max-height: 420px;
    }
    .hs-caption {
      padding: 2rem 1.2rem 4rem;
      gap: 0.5rem;
    }
    .hs-btns {
      gap: 0.6rem;
    }
    .hs-btn {
      padding: 0.65rem 1.2rem;
      font-size: 0.88rem;
    }
  }
</style>

<script>
  const slides = document.querySelectorAll('.hs-slide');
  const dots = document.querySelectorAll('.hs-dot');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (index + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }

  function startAuto() {
    timer = setInterval(() => goTo(current + 1), 5000);
  }

  function resetAuto() {
    clearInterval(timer);
    startAuto();
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = parseInt((dot as HTMLElement).dataset.dot || '0');
      goTo(idx);
      resetAuto();
    });
  });

  startAuto();
</script>
