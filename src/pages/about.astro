---
import BaseLayout from '../layouts/BaseLayout.astro';
import { aboutData } from '../data/siteConfig';
import { Target, Lightbulb, Heart, ShieldCheck } from 'lucide-astro';
---

<BaseLayout title="About Us | Cholo Jai Tour & Travels">
  <section class="page-header">
    <div class="container text-center">
      <h1>About Us</h1>
      <p>Your trusted travel partner for unforgettable journeys.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <h2 class="section-title">Welcome to Cholo Jai Tour & Travels</h2>
          <p class="lead-text">
            We believe that travel is the only thing you buy that makes you richer. Our goal is to craft the perfect itinerary that lets you focus on creating memories while we handle the details.
          </p>
          <p>
            With years of experience in the travel industry, we have built a reputation for excellence, reliability, and personalized service. Whether you are looking for a peaceful mountain retreat, a thrilling wildlife safari, or a relaxing beach holiday, we have the perfect package for you.
          </p>
          
          <div class="experience-box">
            <span class="exp-number">10+</span>
            <span class="exp-text">Years of<br/>Experience</span>
          </div>
        </div>
        <div class="about-image">
          <img src="/images/tour-5.png" alt="Travel Experience" class="main-img" />
          <div class="img-accent"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-light">
    <div class="container">
      <div class="grid grid-2 core-values">
        <div class="value-card">
          <div class="icon-wrapper"><Target size={32} /></div>
          <h3>Our Mission</h3>
          <p>{aboutData.mission}</p>
        </div>
        <div class="value-card">
          <div class="icon-wrapper"><Lightbulb size={32} /></div>
          <h3>Our Vision</h3>
          <p>{aboutData.vision}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header text-center">
        <h2>Why Travel With Us?</h2>
      </div>
      <div class="grid grid-3 text-center">
        <div class="reason-item">
          <div class="icon-circle"><Heart size={28} /></div>
          <h4>Personalized Care</h4>
          <p>Every itinerary is crafted with your specific needs and preferences in mind.</p>
        </div>
        <div class="reason-item">
          <div class="icon-circle"><ShieldCheck size={28} /></div>
          <h4>Trusted & Reliable</h4>
          <p>A government registered agency with thousands of happy travelers.</p>
        </div>
        <div class="reason-item">
          <div class="icon-circle"><Target size={28} /></div>
          <h4>Expert Knowledge</h4>
          <p>Our team knows the destinations inside out to give you the best experience.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    background-color: var(--c-primary);
    color: var(--c-neutral);
    padding: 80px 0;
  }

  .page-header h1 {
    color: var(--c-neutral);
    font-size: 3rem;
    margin-bottom: 15px;
  }

  .page-header p {
    font-size: 1.2rem;
    opacity: 0.9;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .section-title {
    font-size: 2.5rem;
    margin-bottom: 25px;
  }

  .lead-text {
    font-size: 1.2rem;
    color: var(--c-text);
    font-weight: 500;
    margin-bottom: 20px;
    line-height: 1.8;
  }

  .about-content p {
    color: var(--c-text-muted);
    margin-bottom: 20px;
    line-height: 1.8;
  }

  .experience-box {
    display: inline-flex;
    align-items: center;
    gap: 15px;
    background-color: var(--c-bg-light);
    padding: 20px 30px;
    border-radius: var(--radius);
    margin-top: 20px;
    border-left: 4px solid var(--c-accent);
  }

  .exp-number {
    font-size: 3rem;
    font-weight: 700;
    font-family: var(--f-heading);
    color: var(--c-primary);
    line-height: 1;
  }

  .exp-text {
    font-weight: 600;
    color: var(--c-text-muted);
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 1px;
  }

  .about-image {
    position: relative;
    border-radius: var(--radius);
  }

  .main-img {
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    position: relative;
    z-index: 2;
  }

  .img-accent {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 100%;
    height: 100%;
    border: 3px solid var(--c-accent);
    border-radius: var(--radius);
    z-index: 1;
  }

  .bg-light {
    background-color: var(--c-bg-light);
  }

  .value-card {
    background-color: var(--c-neutral);
    padding: 40px;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    text-align: center;
    border: 1px solid var(--c-border);
  }

  .icon-wrapper {
    width: 80px;
    height: 80px;
    background-color: rgba(96, 165, 250, 0.1);
    color: var(--c-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px;
  }

  .value-card h3 {
    font-size: 1.5rem;
    margin-bottom: 15px;
  }

  .value-card p {
    color: var(--c-text-muted);
  }

  .section-header {
    margin-bottom: 50px;
  }

  .section-header h2 {
    font-size: 2.5rem;
  }

  .reason-item {
    padding: 20px;
  }

  .icon-circle {
    width: 70px;
    height: 70px;
    background-color: var(--c-primary);
    color: var(--c-neutral);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }

  .reason-item h4 {
    font-size: 1.25rem;
    margin-bottom: 15px;
  }

  .reason-item p {
    color: var(--c-text-muted);
  }

  @media (max-width: 992px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .img-accent {
      display: none;
    }
  }
</style>
