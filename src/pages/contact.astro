---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/siteConfig';
import { MapPin, Phone, Mail, Send, MessageCircle } from 'lucide-astro';
---

<BaseLayout title="Contact Us | Cholo Jai Tour & Travels">
  <section class="page-header">
    <div class="container text-center">
      <h1>Contact Us</h1>
      <p>We're here to help you plan your next perfect trip.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        
        <!-- Contact Information -->
        <div class="contact-info-panel">
          <h2>Get In Touch</h2>
          <p class="contact-desc">Have questions about a package or need a custom itinerary? Reach out to us through any of these channels.</p>
          
          <ul class="info-list">
            <li>
              <div class="icon-box"><MapPin size={24} /></div>
              <div class="info-details">
                <h3>Our Office</h3>
                <p>{siteConfig.address}</p>
              </div>
            </li>
            <li>
              <div class="icon-box"><Phone size={24} /></div>
              <div class="info-details">
                <h3>Phone</h3>
                <p>{siteConfig.phoneNumbers.join(' / ')}</p>
              </div>
            </li>
            <li>
              <div class="icon-box"><Mail size={24} /></div>
              <div class="info-details">
                <h3>Email</h3>
                <p>{siteConfig.email}</p>
              </div>
            </li>
          </ul>

          <div class="whatsapp-card">
            <MessageCircle size={28} />
            <div class="wa-text">
              <h4>Chat with us directly</h4>
              <p>We are available on WhatsApp</p>
            </div>
            <a href={siteConfig.socials.whatsapp} target="_blank" rel="noopener noreferrer" class="btn btn-primary wa-btn">Message Now</a>
          </div>
        </div>

        <!-- Contact Form (UI Only) -->
        <div class="contact-form-panel">
          <h2>Send us a Message</h2>
          <form class="contact-form" onsubmit="event.preventDefault(); alert('Message sent! (UI Only)');">
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" placeholder="John Doe" required />
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" placeholder="john@example.com" required />
              </div>
              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input type="tel" id="phone" placeholder="+91 98765 43210" required />
              </div>
            </div>

            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" placeholder="Enquiry for Kashmir Tour" required />
            </div>

            <div class="form-group">
              <label for="message">Your Message</label>
              <textarea id="message" rows="5" placeholder="Tell us about your travel plans..." required></textarea>
            </div>

            <button type="submit" class="btn btn-primary submit-btn">
              Send Message <Send size={18} />
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- Map Placeholder -->
  <section class="map-section">
    <div class="map-placeholder">
      <div class="map-content">
        <MapPin size={48} class="map-icon" />
        <h3>Google Maps Placeholder</h3>
        <p>Interactive map centered at: {siteConfig.address}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background-color: var(--c-primary);
    color: var(--c-neutral);
    padding: 80px 0;
  }

  .page-header h1 {
    color: var(--c-neutral);
    font-size: 3rem;
    margin-bottom: 15px;
  }

  .page-header p {
    font-size: 1.2rem;
    opacity: 0.9;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 60px;
  }

  /* Info Panel */
  .contact-info-panel h2, .contact-form-panel h2 {
    font-size: 2rem;
    margin-bottom: 15px;
  }

  .contact-desc {
    color: var(--c-text-muted);
    margin-bottom: 40px;
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 30px;
    margin-bottom: 40px;
  }

  .info-list li {
    display: flex;
    gap: 20px;
  }

  .icon-box {
    width: 60px;
    height: 60px;
    background-color: var(--c-bg-light);
    color: var(--c-primary);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-details h3 {
    font-size: 1.1rem;
    margin-bottom: 5px;
  }

  .info-details p {
    color: var(--c-text-muted);
    line-height: 1.5;
  }

  .whatsapp-card {
    background-color: #25D366; /* WhatsApp Green */
    color: white;
    padding: 30px;
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 15px;
  }

  .wa-text h4 {
    color: white;
    font-size: 1.2rem;
    margin-bottom: 5px;
  }

  .wa-text p {
    opacity: 0.9;
  }

  .wa-btn {
    background-color: white;
    color: #25D366;
    margin-top: 10px;
  }

  .wa-btn:hover {
    background-color: #f0f0f0;
    color: #25D366;
  }

  /* Form Panel */
  .contact-form-panel {
    background-color: var(--c-bg-light);
    padding: 40px;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 30px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-weight: 500;
    font-size: 0.95rem;
  }

  .form-group input,
  .form-group textarea {
    padding: 15px;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 1rem;
    transition: var(--transition);
    background-color: var(--c-neutral);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--c-primary);
    box-shadow: 0 0 0 3px rgba(0, 59, 115, 0.1);
  }

  .submit-btn {
    display: flex;
    gap: 10px;
    margin-top: 10px;
    padding: 15px;
    font-size: 1.1rem;
  }

  /* Map */
  .map-section {
    height: 400px;
    width: 100%;
  }

  .map-placeholder {
    width: 100%;
    height: 100%;
    background-color: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .map-content {
    color: var(--c-text-muted);
  }

  .map-icon {
    margin: 0 auto 15px;
    color: var(--c-primary);
  }

  .map-content h3 {
    color: var(--c-text);
    margin-bottom: 10px;
  }

  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }
    .contact-form-panel {
      padding: 25px;
    }
  }
</style>
