---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSlider from '../components/HeroSlider.astro';
import PackageCard from '../components/PackageCard.astro';
import { packages } from '../data/packages';
import { aboutData } from '../data/siteConfig';
import { Shield, Award, Map, Users } from 'lucide-astro';

const featuredPackages = packages.filter(pkg => pkg.featured).slice(0, 3);
---

<BaseLayout>
  <!-- Hero Section -->
   <!-- Hero Slider -->
   <HeroSlider />

  <!-- Popular Destinations (Visual Grid) -->
  <section class="section bg-light" id="destinations">
    <div class="container">
      <div class="section-header text-center">
        <h2>Popular Destinations</h2>
        <p>Explore our most loved travel spots</p>
      </div>
      
      <div class="destinations-grid">
        <div class="dest-card fade-up" style="--delay:0ms">
          <img src="/images/tour-4.png" alt="Rajasthan" loading="lazy" />
          <div class="dest-content">
            <h3>Rajasthan</h3>
            <a href="https://wa.me/919830905332?text=Hi%2C%20I%20want%20to%20book%20the%20Rajasthan%20tour%20package!" target="_blank" rel="noopener" class="dest-book">📲 Book Now</a>
          </div>
        </div>
        <div class="dest-card fade-up" style="--delay:80ms">
          <img src="/images/tour-1.jpeg" alt="Kashmir" loading="lazy" />
          <div class="dest-content">
            <h3>Kashmir</h3>
            <a href="https://wa.me/919830905332?text=Hi%2C%20I%20want%20to%20book%20the%20Kashmir%20tour%20package!" target="_blank" rel="noopener" class="dest-book">📲 Book Now</a>
          </div>
        </div>
        <div class="dest-card fade-up" style="--delay:160ms">
          <img src="/images/tour-3.png" alt="Andaman" loading="lazy" />
          <div class="dest-content">
            <h3>Andaman</h3>
            <a href="https://wa.me/919830905332?text=Hi%2C%20I%20want%20to%20book%20the%20Andaman%20tour%20package!" target="_blank" rel="noopener" class="dest-book">📲 Book Now</a>
          </div>
        </div>
        <div class="dest-card fade-up" style="--delay:240ms">
          <img src="/images/tour-5.png" alt="Kerala" loading="lazy" />
          <div class="dest-content">
            <h3>Kerala</h3>
            <a href="https://wa.me/919830905332?text=Hi%2C%20I%20want%20to%20book%20the%20Kerala%20tour%20package!" target="_blank" rel="noopener" class="dest-book">📲 Book Now</a>
          </div>
        </div>
        <div class="dest-card fade-up" style="--delay:320ms">
          <img src="/images/tour-7.png" alt="Darjeeling" loading="lazy" />
          <div class="dest-content">
            <h3>Darjeeling</h3>
            <a href="https://wa.me/919830905332?text=Hi%2C%20I%20want%20to%20book%20the%20Darjeeling%20tour%20package!" target="_blank" rel="noopener" class="dest-book">📲 Book Now</a>
          </div>
        </div>
        <div class="dest-card fade-up" style="--delay:400ms">
          <img src="/images/tour-9.png" alt="Goa" loading="lazy" />
          <div class="dest-content">
            <h3>Goa</h3>
            <a href="https://wa.me/919830905332?text=Hi%2C%20I%20want%20to%20book%20the%20Goa%20tour%20package!" target="_blank" rel="noopener" class="dest-book">📲 Book Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section">
    <div class="container">
      <div class="section-header text-center">
        <h2>Why Choose Us</h2>
        <p>We provide the best travel experiences with premium services</p>
      </div>

      <div class="grid grid-4 features-grid">
        <div class="feature-card">
          <div class="feature-icon"><Shield size={32} /></div>
          <h3>Safe Travel</h3>
          <p>Your safety is our top priority. We ensure secure and comfortable journeys.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><Award size={32} /></div>
          <h3>Premium Quality</h3>
          <p>We don't compromise on quality. Best hotels and transport guaranteed.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><Map size={32} /></div>
          <h3>Expert Guides</h3>
          <p>Learn about your destinations with our experienced local tour guides.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><Users size={32} /></div>
          <h3>Family Friendly</h3>
          <p>Packages designed for all age groups to enjoy together seamlessly.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Tours -->
  <section class="section bg-light">
    <div class="container">
      <div class="section-header text-center">
        <h2>Featured Tours</h2>
        <p>Our handpicked premium travel packages</p>
      </div>

      <div class="grid grid-3">
        {featuredPackages.map(pkg => (
          <PackageCard pkg={pkg} />
        ))}
      </div>
      
      <div class="text-center view-all-btn">
        <a href="/packages" class="btn btn-secondary">View All Packages</a>
      </div>
    </div>
  </section>

  <!-- Statistics -->
  <section class="section stats-section">
    <div class="container">
      <div class="grid grid-4 text-center">
        {aboutData.stats.map(stat => (
          <div class="stat-item">
            <h3 class="stat-value">{stat.value}</h3>
            <p class="stat-label">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section cta-section">
    <div class="container text-center">
      <h2>Ready for your next adventure?</h2>
      <p>Contact us today and let us plan the perfect holiday for you.</p>
      <a href="https://wa.me/919830905332?text=Hi%2C%20I%20want%20to%20book%20a%20tour%20with%20Cholo%20Jai%20Tour%20%26%20Travels!" target="_blank" rel="noopener" class="btn btn-primary cta-btn">📲 Book on WhatsApp</a>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    height: 80vh;
    min-height: 600px;
    background-image: url('/images/tour-2.png');
    background-size: cover;
    background-position: center;
    position: relative;
    display: flex;
    align-items: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: var(--c-neutral);
    max-width: 800px;
  }

  .hero-title {
    font-size: clamp(3rem, 5vw, 4.5rem);
    color: var(--c-neutral);
    margin-bottom: 20px;
    font-weight: 700;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    opacity: 0.9;
    margin-bottom: 40px;
    line-height: 1.8;
    max-width: 600px;
  }

  .hero-cta {
    display: flex;
    gap: 20px;
  }

  .section-header {
    margin-bottom: 50px;
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 15px;
  }

  .section-header p {
    color: var(--c-text-muted);
    font-size: 1.1rem;
  }

  .bg-light {
    background-color: var(--c-bg-light);
  }

  /* Destinations */
  .destinations-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  @media (max-width: 480px) {
    .destinations-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
  }

  .dest-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    height: 200px;
    display: block;
    cursor: pointer;
    /* fade-up start state */
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.55s ease, transform 0.55s ease;
    transition-delay: var(--delay, 0ms);
  }

  .dest-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .dest-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .dest-card:hover img {
    transform: scale(1.08);
  }

  .dest-content {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 55%);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 12px;
    gap: 6px;
  }

  .dest-content h3 {
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  .dest-book {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: #25D366;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    white-space: nowrap;
  }

  .dest-book:hover {
    background: #1db954;
    transform: scale(1.05);
  }

  /* Features */
  .feature-card {
    text-align: center;
    padding: 30px 20px;
  }

  .feature-icon {
    width: 70px;
    height: 70px;
    background-color: var(--c-bg-light);
    color: var(--c-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    transition: var(--transition);
  }

  .feature-card:hover .feature-icon {
    background-color: var(--c-accent);
    color: var(--c-neutral);
    transform: translateY(-5px);
  }

  .feature-card h3 {
    font-size: 1.25rem;
    margin-bottom: 15px;
  }

  .feature-card p {
    color: var(--c-text-muted);
  }

  .view-all-btn {
    margin-top: 50px;
  }

  /* Stats */
  .stats-section {
    background-color: var(--c-primary);
    color: var(--c-neutral);
  }

  .stat-value {
    font-size: 3rem;
    color: var(--c-neutral);
    margin-bottom: 10px;
  }

  .stat-label {
    opacity: 0.8;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* CTA */
  .cta-section {
    background-color: var(--c-bg-light);
    padding: 100px 0;
  }

  .cta-section h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
  }

  .cta-section p {
    font-size: 1.2rem;
    color: var(--c-text-muted);
    margin-bottom: 40px;
  }

  .cta-btn {
    font-size: 1.1rem;
    padding: 15px 40px;
  }

  @media (max-width: 768px) {
    .hero-cta {
      flex-direction: column;
    }
  }
</style>

<script>
  // Scroll-triggered fade-up for destination cards
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>
