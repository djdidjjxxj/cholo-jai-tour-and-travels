---
import BaseLayout from '../layouts/BaseLayout.astro';
import PackageCard from '../components/PackageCard.astro';
import { packages } from '../data/packages';
import { Search, Filter } from 'lucide-astro';
---

<BaseLayout title="Tour Packages | Cholo Jai Tour & Travels">
  <section class="page-header">
    <div class="container text-center">
      <h1>Our Tour Packages</h1>
      <p>Discover our wide range of premium travel experiences.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      
      <!-- Static Filter & Search UI -->
      <div class="filter-bar">
        <div class="search-box">
          <Search size={20} class="icon" />
          <input type="text" placeholder="Search destinations..." class="search-input" />
        </div>
        
        <div class="filter-actions">
          <div class="filter-dropdown">
            <Filter size={18} class="icon" />
            <select class="select-input">
              <option value="">All Destinations</option>
              <option value="kashmir">Kashmir</option>
              <option value="darjeeling">Darjeeling</option>
              <option value="andaman">Andaman</option>
              <option value="rajasthan">Rajasthan</option>
              <option value="kerala">Kerala</option>
              <option value="goa">Goa</option>
            </select>
          </div>
          <div class="filter-dropdown">
            <select class="select-input">
              <option value="">Sort By</option>
              <option value="price-low">Price: Low to High</option>
              <option value="price-high">Price: High to Low</option>
              <option value="duration">Duration</option>
            </select>
          </div>
        </div>
      </div>

      <div class="grid grid-3">
        {packages.map(pkg => (
          <PackageCard pkg={pkg} />
        ))}
      </div>
      
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background-color: var(--c-primary);
    color: var(--c-neutral);
    padding: 80px 0;
  }

  .page-header h1 {
    color: var(--c-neutral);
    font-size: 3rem;
    margin-bottom: 15px;
  }

  .page-header p {
    font-size: 1.2rem;
    opacity: 0.9;
  }

  .filter-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: var(--c-neutral);
    padding: 20px;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    margin-bottom: 40px;
    border: 1px solid var(--c-border);
    flex-wrap: wrap;
    gap: 20px;
  }

  .search-box {
    display: flex;
    align-items: center;
    background-color: var(--c-bg-light);
    border-radius: var(--radius-sm);
    padding: 0 15px;
    flex: 1;
    max-width: 400px;
  }

  .search-box .icon {
    color: var(--c-text-muted);
  }

  .search-input {
    border: none;
    background: transparent;
    padding: 12px 10px;
    width: 100%;
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--c-text);
  }

  .search-input:focus {
    outline: none;
  }

  .filter-actions {
    display: flex;
    gap: 15px;
  }

  .filter-dropdown {
    display: flex;
    align-items: center;
    background-color: var(--c-bg-light);
    border-radius: var(--radius-sm);
    padding: 0 15px;
  }

  .filter-dropdown .icon {
    color: var(--c-text-muted);
  }

  .select-input {
    border: none;
    background: transparent;
    padding: 12px 10px;
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--c-text);
    cursor: pointer;
  }

  .select-input:focus {
    outline: none;
  }

  @media (max-width: 768px) {
    .filter-bar {
      flex-direction: column;
      align-items: stretch;
    }
    .search-box {
      max-width: 100%;
    }
    .filter-actions {
      flex-direction: column;
    }
  }
</style>
